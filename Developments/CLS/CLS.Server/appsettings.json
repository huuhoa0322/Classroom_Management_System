{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "JwtSettings": {
    "Issuer": "cls-api",
    "Audience": "cls-client",
    "SecretKey": "",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": { "Microsoft": "Warning", "Microsoft.EntityFrameworkCore": "Warning" }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/cls-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "AutoMapper": {
    "LicenseKey": ""
  },
  "EmailSettings": {
    "DispatchIntervalMinutes": 5,
    "BatchSize": 50,
    "MaxRetries": 3,
    "Smtp": {
      "Host": "smtp.gmail.com",
      "Port": 465,
      "Username": "",
      "Password": "",
      "FromEmail": "",
      "FromName": "CLS - Classroom Management System",
      "EnableSsl": true
    }
  },
  "AllowedHosts": "*"
}
