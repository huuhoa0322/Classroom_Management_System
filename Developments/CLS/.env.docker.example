# =============================================================================
# CLS — Docker Compose Environment Variables
# =============================================================================
# Copy file này → .env  rồi điền giá trị thật.
# File .env KHÔNG được commit lên Git (đã nằm trong .gitignore).
#
# Tạo JWT secret:   openssl rand -hex 32
# =============================================================================


# ── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# Lấy từ: Supabase Dashboard → Project Settings → Database → Connection string
#
# Format:
#   Host=db.xxxxxxxxxxxx.supabase.co;Port=6543;Database=postgres;Username=postgres;Password=<your-password>;SSL Mode=Require;Trust Server Certificate=true;Pooling=false
#
# Lưu ý:
#   - Port 6543 = Transaction Pooler (recommended)
#   - Port 5432 = Direct connection
#   - Pooling=false bắt buộc khi dùng Supabase Transaction Pooler

DATABASE_URL=Host=db.xxxxxxxxxxxx.supabase.co;Port=6543;Database=postgres;Username=postgres;Password=YOUR_SUPABASE_PASSWORD;SSL Mode=Require;Trust Server Certificate=true;Pooling=false


# ── JWT Authentication ──────────────────────────────────────────────────────
# SecretKey: tối thiểu 32 ký tự (256-bit), random entropy cao
# Tạo key: openssl rand -hex 32

JWT_SECRET_KEY=                             # ← BẮT BUỘC


# ── Application ─────────────────────────────────────────────────────────────
API_PORT=8080
ASPNETCORE_ENVIRONMENT=Production


# ── CORS (URL frontend) ────────────────────────────────────────────────────
# Dev:  http://localhost:5173
# Prod: https://cls.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173


# =============================================================================
# CHỈ DÙNG KHI CHẠY LOCAL DB (docker compose --profile local-db up -d)
# Nếu dùng Supabase thì KHÔNG cần điền phần dưới
# =============================================================================

# POSTGRES_DB=cls_dev
# POSTGRES_USER=cls_admin
# POSTGRES_PASSWORD=localpass123
# DB_PORT=5432
# DATABASE_URL=Host=cls-db;Port=5432;Database=cls_dev;Username=cls_admin;Password=localpass123;Pooling=true
