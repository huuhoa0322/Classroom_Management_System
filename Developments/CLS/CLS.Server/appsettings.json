{
  "ConnectionStrings": {
    "DefaultConnection": "Host=...;Database=cls_db;Username=...;Password=..."
  },
  "JwtSettings": {
    "Issuer": "cls-api",
    "Audience": "cls-client",
    "SecretKey": "CHANGE_ME_IN_USER_SECRETS",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": { "Microsoft": "Warning" }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/cls-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
