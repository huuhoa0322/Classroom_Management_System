# ==============================================================================
# CLS — Environment Variables Template
# ==============================================================================
# File này tài liệu hóa toàn bộ biến môi trường cần thiết để chạy CLS.Server.
# KHÔNG điền giá trị thật vào file này — commit file này lên Git là an toàn.
#
# ── Môi trường Local Development ──────────────────────────────────────────────
# Dùng .NET User Secrets thay vì file .env:
#   cd CLS.Server
#   dotnet user-secrets set "ConnectionStrings:DefaultConnection" "Host=...;..."
#   dotnet user-secrets set "JwtSettings:SecretKey" "<your-secret>"
#
# ── Môi trường Staging / Production ──────────────────────────────────────────
# Set các biến môi trường hệ thống với format dưới dây.
# ASP.NET Core tự động đọc biến môi trường và override appsettings.json.
# Dấu ":" trong key JSON được thay bằng "__" (double underscore) trong env var.
#
# Ví dụ:
#   ConnectionStrings__DefaultConnection  → override "ConnectionStrings.DefaultConnection"
#   JwtSettings__SecretKey                → override "JwtSettings.SecretKey"
# ==============================================================================


# ── Database (Supabase / PostgreSQL) ──────────────────────────────────────────
# Format Npgsql:
#   Host=<host>;Database=<db>;Username=<user>;Password=<pass>;Port=<port>;
#   SSL Mode=Require;Trust Server Certificate=true;Pooling=false
#
# Lưu ý: Pooling=false bắt buộc khi dùng Transaction Pooler port 6543 (Supabase)

ConnectionStrings__DefaultConnection=


# ── JWT Authentication ────────────────────────────────────────────────────────
# SecretKey: tối thiểu 32 ký tự (256-bit), random entropy cao.
# Tạo key: openssl rand -hex 32

JwtSettings__SecretKey=
JwtSettings__Issuer=cls-api
JwtSettings__Audience=cls-client
JwtSettings__AccessTokenExpiryMinutes=60
JwtSettings__RefreshTokenExpiryDays=7


# ── CORS (nếu cần whitelist domain FE cụ thể) ────────────────────────────────
# Mặc định AllowedHosts=* trong appsettings.json

# AllowedHosts=https://cls.yourdomain.com
