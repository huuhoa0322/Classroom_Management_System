# =============================================================================
# CLS — Environment Variables (ASP.NET Core format)
# =============================================================================
# Dùng chung cho: Docker Compose + Render.com
# Copy file này → .env rồi điền giá trị thật.
# File .env KHÔNG commit lên Git.
#
# Tên biến dùng format ASP.NET Core: Section__Key (double underscore)
# =============================================================================


# ── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# Lấy từ: Supabase Dashboard → Project Settings → Database
ConnectionStrings__DefaultConnection=Host=db.xxxxxxxxxxxx.supabase.co;Port=6543;Database=postgres;Username=postgres;Password=YOUR_SUPABASE_PASSWORD;SSL Mode=Require;Trust Server Certificate=true;Pooling=false


# ── JWT Authentication ──────────────────────────────────────────────────────
# SecretKey: tối thiểu 32 ký tự — tạo bằng: openssl rand -hex 32
JwtSettings__SecretKey=
JwtSettings__Issuer=cls-api
JwtSettings__Audience=cls-client
JwtSettings__AccessTokenExpiryMinutes=60
JwtSettings__RefreshTokenExpiryDays=7


# ── Application ─────────────────────────────────────────────────────────────
API_PORT=8080
ASPNETCORE_ENVIRONMENT=Production


# ── CORS ────────────────────────────────────────────────────────────────────
AllowedOrigins=http://localhost:5173


# =============================================================================
# CHỈ DÙNG KHI CHẠY LOCAL DB (docker compose --profile local-db up -d)
# =============================================================================
# POSTGRES_DB=cls_dev
# POSTGRES_USER=cls_admin
# POSTGRES_PASSWORD=localpass123
# DB_PORT=5432
# ConnectionStrings__DefaultConnection=Host=cls-db;Port=5432;Database=cls_dev;Username=cls_admin;Password=localpass123;Pooling=true
